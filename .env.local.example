# SignalDesk AI - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================
# GOOGLE AI (Required for AI features)
# Get your free key at: https://aistudio.google.com
# ============================================================
GOOGLE_AI_API_KEY=your-google-ai-key-here

# ============================================================
# SUPABASE (Optional - enables auth and persistent storage)
# Get your values at: https://app.supabase.com
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# REDDIT API (Optional - for higher rate limits)
# Get your credentials at: https://www.reddit.com/prefs/apps
# Without this, the app uses the public Reddit API (limited)
# ============================================================
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USERNAME=your-reddit-username

# ============================================================
# APP CONFIG
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
